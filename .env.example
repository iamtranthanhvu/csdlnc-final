# =============================================================
# Docker project
# =============================================================
COMPOSE_PROJECT_NAME=csdlnc
APP_PORT=3000

# Commands injected into container CMD
DEV_COMMAND=npm run dev
DEV_WORKER_COMMAND=npm run dev:worker
PROD_COMMAND=node dist/server.js
PROD_WORKER_COMMAND=node dist/worker.js

# =============================================================
# PostgreSQL image init vars (used by postgres:16 image)
# =============================================================
POSTGRES_DB=ecommerce
POSTGRES_USER=admin
POSTGRES_PASSWORD=secret

# =============================================================
# MongoDB image init vars
# =============================================================
MONGO_INITDB_DATABASE=ecommerce

# =============================================================
# RabbitMQ image init vars
# =============================================================
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=secret

# =============================================================
# App DB connection (Docker hostnames — không cần thay đổi)
# =============================================================
PG_MASTER_HOST=csdl_db_master
PG_MASTER_PORT=5432
PG_SLAVE_HOST=csdl_db_slave
PG_SLAVE_PORT=5432
PG_DATABASE=ecommerce
PG_USER=admin
PG_PASSWORD=secret
PG_READONLY_USER=admin
PG_READONLY_PASSWORD=secret
PG_REPLICATION_PASSWORD=replicatorpass

# Prisma CLI
DATABASE_URL=postgresql://admin:secret@csdl_db_master:5432/ecommerce

# MongoDB
MONGO_URI=mongodb://csdl_mongodb:27017/ecommerce

# RabbitMQ
RABBITMQ_URL=amqp://admin:secret@csdl_queue:5672

# =============================================================
# Thay các giá trị bên dưới trước khi chạy
# =============================================================

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=3600
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=604800

# SMTP (gửi email cho vendor)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@techshop.vn
SMTP_PASS=smtp_password
SMTP_FROM=TechShop <noreply@techshop.vn>

# Server
PORT=3000
NODE_ENV=development
